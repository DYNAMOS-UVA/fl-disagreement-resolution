{
  "name": "Basic Disagreements",
  "description": "A simple scenario with basic disagreements to test the core functionality. Client 0 disagrees with client 1, and client 2 disagrees with client 3.",
  "num_clients": 6,
  "expected_tracks": {
    "track_0_no1": "For client 0, excluding client 1",
    "track_2_no3": "For client 2, excluding client 3",
    "global": "Global track (for clients 1, 3, 4, 5 without specific disagreements)"
  },
  "validation_rules": {
    "round_1_rules": [
      {
        "type": "client_excludes",
        "client": 0,
        "excludes": [1],
        "description": "Client 0's track should exclude client 1"
      },
      {
        "type": "client_excludes",
        "client": 2,
        "excludes": [3],
        "description": "Client 2's track should exclude client 3"
      },
      {
        "type": "clients_on_track",
        "track_name": "global",
        "clients": [1, 3, 4, 5],
        "description": "Clients 1, 3, 4, 5 should be on the global track"
      }
    ]
  },
  "disagreements": {
    "client_0": [
      {
        "type": "inbound",
        "target": "client_1",
        "active_rounds": {
          "start": 1,
          "end": null
        }
      }
    ],
    "client_2": [
      {
        "type": "inbound",
        "target": "client_3",
        "active_rounds": {
          "start": 1,
          "end": null
        }
      }
    ]
  }
}
